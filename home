<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Falno Bot — Multi-Tool Discord Suite</title>
    <style>
        /* Modern Discord Dark Aesthetic */
        :root {
            --bg-main: #0f1115;
            --bg-card: #181c25;
            --accent: #5865F2; /* Discord Blurple */
            --accent-hover: #4752C4;
            --text-main: #f3f4f6;
            --text-muted: #9ca3af;
            --border: #262d3d;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }

        body {
            background-color: var(--bg-main);
            color: var(--text-main);
            line-height: 1.6;
            display: flex;
            flex-direction: column;
            min-height: 100vh;
        }

        /* Navbar Layout */
        header {
            background-color: var(--bg-card);
            border-bottom: 1px solid var(--border);
            padding: 1rem 2rem;
            position: sticky;
            top: 0;
            z-index: 100;
        }

        .nav-container {
            max-width: 1100px;
            margin: 0 auto;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .logo {
            font-size: 1.5rem;
            font-weight: 700;
            color: var(--text-main);
            text-decoration: none;
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        .logo span {
            color: var(--accent);
        }

        nav {
            display: flex;
            gap: 1.5rem;
        }

        nav a {
            color: var(--text-muted);
            text-decoration: none;
            font-weight: 500;
            transition: color 0.2s;
            cursor: pointer;
        }

        nav a:hover, nav a.active {
            color: var(--text-main);
        }

        /* Core Content Container */
        main {
            max-width: 900px;
            width: 100%;
            margin: 0 auto;
            padding: 3rem 2rem;
            flex-grow: 1;
        }

        .page-section {
            display: none; /* Controlled by JavaScript hash matching */
            animation: fadeIn 0.3s ease-in-out;
        }

        .page-section.active {
            display: block;
        }

        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }

        /* Home Page/Landing Styling */
        .hero {
            text-align: center;
            padding: 4rem 0;
        }

        .hero h1 {
            font-size: 3.5rem;
            margin-bottom: 1rem;
            font-weight: 800;
        }

        .hero p {
            font-size: 1.25rem;
            color: var(--text-muted);
            max-width: 600px;
            margin: 0 auto 2.5rem auto;
        }

        .btn {
            background-color: var(--accent);
            color: white;
            padding: 0.8rem 2rem;
            font-size: 1.1rem;
            font-weight: 600;
            border-radius: 8px;
            text-decoration: none;
            transition: background-color 0.2s;
            display: inline-block;
            box-shadow: 0 4px 14px rgba(88, 101, 242, 0.3);
        }

        .btn:hover {
            background-color: var(--accent-hover);
        }

        /* Feature Matrix Grid */
        .features-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 1.5rem;
            margin-top: 3rem;
        }

        .feature-card {
            background-color: var(--bg-card);
            border: 1px solid var(--border);
            padding: 1.5rem;
            border-radius: 12px;
        }

        .feature-card h3 {
            margin-bottom: 0.5rem;
            color: var(--text-main);
        }

        .feature-card p {
            color: var(--text-muted);
            font-size: 0.95rem;
        }

        /* Document Styling (Privacy/Terms) */
        .doc-panel {
            background-color: var(--bg-card);
            border: 1px solid var(--border);
            padding: 2.5rem;
            border-radius: 16px;
        }

        .doc-panel h2 {
            font-size: 2rem;
            margin-bottom: 0.5rem;
            border-bottom: 2px solid var(--border);
            padding-bottom: 0.5rem;
        }

        .doc-panel .date {
            color: var(--text-muted);
            font-size: 0.9rem;
            margin-bottom: 2rem;
        }

        .doc-panel h4 {
            font-size: 1.2rem;
            margin: 1.5rem 0 0.5rem 0;
            color: var(--accent);
        }

        .doc-panel ul {
            margin-left: 1.5rem;
            margin-bottom: 1rem;
            color: var(--text-muted);
        }

        .doc-panel p {
            color: var(--text-muted);
            margin-bottom: 1rem;
        }

        /* Footer Layout */
        footer {
            background-color: var(--bg-card);
            border-top: 1px solid var(--border);
            text-align: center;
            padding: 1.5rem;
            color: var(--text-muted);
            font-size: 0.9rem;
            margin-top: auto;
        }
    </style>
</head>
<body>

    <header>
        <div class="nav-container">
            <a href="#home" class="logo">⚡ Falno<span>.</span></a>
            <nav>
                <a href="#home" id="nav-home">Home</a>
                <a href="#privacy" id="nav-privacy">Privacy Policy</a>
                <a href="#terms" id="nav-terms">Terms of Service</a>
            </nav>
        </div>
    </header>

    <main>
        
        <section id="home" class="page-section">
            <div class="hero">
                <h1>Meet <span>Falno</span></h1>
                <p>An ultra-optimized, lightweight community suite designed to consolidate your server features without the bot bloat.</p>
                <a href="#" target="_blank" class="btn">Add Falno to Discord</a>
            </div>

            <div class="features-grid">
                <div class="feature-card">
                    <h3>🔔 YouTube Alerts</h3>
                    <p>Highly optimized uploads tracker using ultra-frugal quota routing to deliver instant notification embeds.</p>
                </div>
                <div class="feature-card">
                    <h3>🤫 Confessions Suite</h3>
                    <p>Interactive configuration modals featuring full moderator authorization approval workflows.</p>
                </div>
                <div class="feature-card">
                    <h3>🎲 Interactive Games</h3>
                    <p>Persistent self-cleaning Truth or Dare engines, daily quote broadcasts, and classic chat mini-games.</p>
                </div>
            </div>
        </section>

        <section id="privacy" class="page-section">
            <div class="doc-panel">
                <h2>Privacy Policy</h2>
                <div class="date">Last Updated: June 2026</div>
                
                <h4>1. What Data We Collect</h4>
                <p>Falno operates on a minimal data layout model to maximize processing efficiency and protect user data structure isolation:</p>
                <ul>
                    <li><strong>Server & Channel IDs:</strong> Saved uniquely to bind active notification hubs, confession routes, and daily global broadcasts.</li>
                    <li><strong>YouTube Channel IDs:</strong> Stored to pass to deduplicated polling maps for background update sweeps.</li>
                    <li><strong>Transient Interaction Footprints:</strong> Session data generated by interactive UI components (such as Truth or Dare button instances) is processed entirely within ephemeral context windows and never committed to disk storage.</li>
                </ul>

                <h4>2. What We Do Not Collect</h4>
                <p>We believe in absolute data minimization. Falno explicitly bypasses the caching or tracking of standard messaging arrays. Real user metadata belongs exclusively to you; user identities for anonymous confession records are scrubbed completely prior to execution serialization.</p>

                <h4>3. Data Integrity & Removal</h4>
                <p>Data maps are isolated securely and never exposed to secondary platforms. If you wish to wipe your configuration data maps entirely, removing the bot from your guild will invoke automated cleanup cycles that securely drop obsolete configurations from our system maps.</p>
            </div>
        </section>

        <section id="terms" class="page-section">
            <div class="doc-panel">
                <h2>Terms of Service</h2>
                <div class="date">Last Updated: June 2026</div>

                <h4>1. Acceptance of Terms</h4>
                <p>By connecting Falno to your active Discord spaces or executing its runtime utilities, you explicitly agree to conform to these Terms of Service alongside the standard Discord Community Guidelines.</p>

                <h4>2. Operational Bound Rules</h4>
                <p>Users agree to refrain from exploiting any component of the system to orchestrate distributed service disruptions, spam concurrent API request nodes, or leverage the anonymous translation hooks to execute targeted harassment actions against other individuals.</p>

                <h4>3. Liability Disclaimer</h4>
                <p>Falno is deployed completely on an "as-is" structural configuration model. The development ecosystem holds no liability for down-time disruptions resulting from upstream API modifications, host connectivity cycles, or unmoderated content delivered via active deployment setups.</p>

                <h4>4. Access Revocation</h4>
                <p>The system operator reserves the absolute right to drop data links or implement network restrictions against any guild configuration found intentionally compromising active operations.</p>
            </div>
        </section>

    </main>

    <footer>
        &copy; 2026 Falno Bot. Built with optimization in mind.
    </footer>

    <script>
        function router() {
            // Default to #home if no hash or invalid hash is supplied
            const hash = window.location.hash || '#home';
            
            // Query sections and navigation elements
            const sections = document.querySelectorAll('.page-section');
            const navLinks = document.querySelectorAll('nav a');
            
            let targetSection = document.querySelector(hash);
            if (!targetSection) {
                window.location.hash = '#home';
                return;
            }

            // Toggle active states efficiently
            sections.forEach(s => s.classList.remove('active'));
            navLinks.forEach(l => l.classList.remove('active'));

            targetSection.classList.add('active');
            
            const activeNav = document.getElementById(`nav-${hash.replace('#', '')}`);
            if (activeNav) activeNav.classList.add('active');

            // Instantly scroll back to the top of the viewport on tab switch
            window.scrollTo(0, 0);
        }

        // Run router on initial document load and whenever the URL hash changes
        window.addEventListener('hashchange', router);
        window.addEventListener('load', router);
    </script>
</body>
</html>
